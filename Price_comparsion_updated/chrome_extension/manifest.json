{
  "manifest_version": 3,
  "name": "CodeSky Price Comparator",
  "version": "1.0",
  "description": "Compare prices between Amazon and Walmart instantly.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "contextMenus",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",  
    "http://localhost:5000/*"   
  ],
  "background": {
    "service_worker": "background.js"
  }
}
